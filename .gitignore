# Byte-compiled / cache
__pycache__/
*.py[cod]
*.pyc

# Virtual environments
venv/
.venv/
env/

# Jupyter
.ipynb_checkpoints/

# Data (never commit raw/interim/processed research data)
data/raw/*
data/interim/*
data/processed/*
data/external/*
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep
!data/external/.gitkeep

# Secrets / credentials
.env
*.env
configs/secrets.yaml

# OS junk
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Model artifacts (large binary files)
*.pkl
*.pt
*.h5
models/*.bin

# Build artifacts
build/
dist/
*.egg-info/
